// Pmais+ — controle financeiro de eventos
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Auth (NextAuth v5 + Prisma adapter)
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // null para contas OAuth futuras
  role          UserRole  @default(PRODUTOR)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  ADMIN
  PRODUTOR
  FINANCEIRO
}

// ─────────────────────────────────────────────
// Domínio — Evento e financeiro
// ─────────────────────────────────────────────

model Event {
  id           String   @id @default(cuid())
  name         String
  cliente      String?
  local        String?
  publicoAlvo  String?
  produtorNome String?
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  expenseCategories ExpenseCategory[]
  suppliers         Supplier[]
  revenues          RevenueItem[]
}

model ExpenseCategory {
  id      String @id @default(cuid())
  eventId String
  name    String
  order   Int    @default(0)

  event Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items ExpenseItem[]

  @@index([eventId])
}

model ExpenseItem {
  id         String @id @default(cuid())
  categoryId String
  servico    String
  descritivo String?

  // Planejado
  planejadoQtdItens   Int?
  planejadoQtdDias    Int?
  planejadoValorUnit  Float?
  planejadoValorTotal Float?

  // Orçado
  orcadoQtdItens   Int?
  orcadoQtdDias    Int?
  orcadoValorUnit  Float?
  orcadoValorTotal Float?

  // Contratado
  contratadoQtdItens   Int?
  contratadoQtdDias    Int?
  contratadoValorUnit  Float?
  contratadoValorTotal Float?

  // Área do Produtor
  statusProdutor StatusProdutor @default(EM_COTACAO)
  supplierId     String?

  // Área do Financeiro
  statusFinanceiro StatusFinanceiro @default(AGUARDANDO_APROVACAO)
  dataPagamento    DateTime?
  valorPago        Float?
  obsParcelas      String?

  // BV (Business Value / comissão)
  bvAcordado  Float?
  bvRecebido  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  supplier Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([supplierId])
}

model Supplier {
  id       String  @id @default(cuid())
  eventId  String
  empresa  String
  contato  String?
  telefone String?
  email    String?

  event Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items ExpenseItem[]

  @@index([eventId])
}

model RevenueItem {
  id         String      @id @default(cuid())
  eventId    String
  type       RevenueType
  descritivo String

  planejadoQtd        Int?
  planejadoValorTotal Float?
  realizadoQtd        Int?
  realizadoValorTotal Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

enum StatusProdutor {
  APROVADO
  AGUARDANDO_APROVACAO
  NEGOCIACAO
  EM_COTACAO
}

enum StatusFinanceiro {
  SOLICITADO
  RECEBIDO
  ENVIADO_LANCADO
  PAGO
  AGUARDANDO_APROVACAO
}

enum RevenueType {
  INSCRICAO
  PATROCINIO
  OUTRAS
}
